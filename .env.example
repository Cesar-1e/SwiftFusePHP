# SwiftFusePHP environment configuration.
# Copy this file to ".env" and adjust the values, then run: php fuse key:generate

# --- Application ---
APP_NAME=SwiftFusePHP
APP_ENV=local
APP_DEBUG=true
APP_VERSION=0.9.9
APP_URL=http://localhost
APP_LOCALE=en
APP_TIMEZONE=America/Bogota
# Generated automatically by "php fuse key:generate".
APP_KEY=

# --- Database (PDO) ---
DB_DRIVER=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=swiftfusephp_test
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4
DB_PERSISTENT=true
DB_SSL_CA=

# --- Storage / protected file delivery ---
# accel: none | apache (mod_xsendfile) | nginx (X-Accel-Redirect)
STORAGE_ACCEL=none
STORAGE_NGINX_INTERNAL=/protected/

# --- Background queue ---
# driver: file | async
QUEUE_DRIVER=file

# --- Integrations ---
RECAPTCHA_KEY=
